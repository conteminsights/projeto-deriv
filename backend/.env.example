# ZeeK.Web Backend
# Copy this to .env and adjust

# App
APP_NAME=ZeeK.Web
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-32-bytes-min

# Database (SQLite dev / PostgreSQL prod)
DATABASE_URL=sqlite+aiosqlite:///./data/zeek.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zeek

# Redis (opcional, para filas)
REDIS_URL=redis://localhost:6379

# Deriv
DERIV_APP_ID=24332
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3
DERIV_API_URL=https://api.derivws.com

# Monitor
MONITOR_URL=http://79.143.190.252:8765/api/v1
MONITOR_ENABLED=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# License
LICENSE_VALIDATION_URL=http://79.143.190.252:8765/api/v1/license/validate
